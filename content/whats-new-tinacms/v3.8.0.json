      "changesTitle": "Patch Changes",
      "changesList": [
        {
          "changesDescription": "Fix crash in `getFieldGroup` when editing deeply nested rich-text fields (3+ levels) with templates. The method used `findIndex` which always searched from the start of the path array, causing it to resolve the wrong \"children\"/\"props\" segments on recursive calls. Replaced with `indexOf` searching from the current position, and added a null guard for graceful fallback on malformed content.",
          "pull_request_number": "6694",
          "pull_request_link": "https://github.com/tinacms/tinacms/pull/6694",
          "commit_hash": "723632b",
          "commit_link": "https://github.com/tinacms/tinacms/commit/723632b050b1e9502c46215fd6e8e548cc108ac0",
          "gitHubName": "alhafoudh",
